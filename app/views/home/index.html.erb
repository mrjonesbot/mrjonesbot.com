<div style="min-height: 100vh; padding: var(--space-12) var(--space-6);">
  <!-- Theme Toggle -->
  <div style="position: fixed; top: var(--space-5); right: var(--space-5); z-index: 40;">
    <button
      data-action="click->theme#toggle"
      data-theme-target="toggle"
      class="btn btn--ghost"
      style="width: 44px; height: 44px; padding: 0; border-radius: var(--radius-full);"
      aria-label="Toggle theme"
    >
      <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
      </svg>
    </button>
  </div>

  <!-- Bento Grid Container -->
  <div style="max-width: 1400px; margin: 0 auto;">
    <div class="bento-grid">
      <!-- Row 1: Hero Card (col-span-2) -->
      <div class="card col-span-2">
        <p class="card__label">Developer, Founder, and Baker</p>
        <h1 class="text-display" style="margin-bottom: var(--space-4);">Nathan J.</h1>
        <p class="text-body">
        I'm a software developer based in Chicago, Illinois. <br>I'm the founder of Nestingbird, HOA management software for self-managed communities and property managers. I love baking sourdough.
        </p>
      </div>

      <!-- Row 1: Building Card (col-span-1, accent) - Rotating -->
      <a
        href="<%= @building_projects.first[:url] %>"
        target="_blank"
        rel="noopener noreferrer"
        class="col-span-1"
        style="text-decoration: none; display: block; position: relative;"
        data-controller="rotating-card"
        data-rotating-card-projects-value="<%= @building_projects.to_json %>"
        data-rotating-card-interval-value="6000"
        data-action="mouseenter->rotating-card#pause mouseleave->rotating-card#resume"
      >
        <!-- Timer indicator -->
        <div style="position: absolute; top: var(--space-4); right: var(--space-4); z-index: 10;">
          <svg width="20" height="20" viewBox="0 0 20 20" style="transform: rotate(-90deg);">
            <circle
              cx="10"
              cy="10"
              r="8"
              fill="none"
              stroke="rgba(255,255,255,0.2)"
              stroke-width="2"
            />
            <circle
              cx="10"
              cy="10"
              r="8"
              fill="none"
              stroke="rgba(255,255,255,0.8)"
              stroke-width="2"
              stroke-linecap="round"
              data-rotating-card-target="progress"
              style="transition: stroke-dashoffset 0.1s linear;"
            />
          </svg>
        </div>

        <div class="card card--accent" data-rotating-card-target="card" style="transition: opacity 0.3s ease, transform 0.3s ease; height: 100%;">
          <p class="card__label">Building</p>
          <h2 class="card__title" style="font-size: var(--text-2xl); margin-bottom: var(--space-2);" data-card-title><%= @building_projects.first[:name] %></h2>
          <p style="color: rgba(255,255,255,0.8); font-size: var(--text-base);" data-card-description><%= @building_projects.first[:description] %></p>
        </div>
      </a>

      <!-- Row 1: Location Card (col-span-1) -->
      <div class="card col-span-1">
        <p class="card__label">Location</p>
        <h2 class="card__title" style="font-size: var(--text-2xl); margin-bottom: var(--space-4);"><%= @location %></h2>
        <% if @open_to_work %>
          <div class="status status--available">
            <span class="status__dot"></span>
            Open to work
          </div>
        <% end %>
      </div>

      <!-- Row 2: Stack Card (col-span-2) -->
      <div class="card col-span-2">
        <p class="card__label">Stack</p>
        <div class="flex flex-wrap gap-3" style="display: flex; flex-wrap: wrap; gap: var(--space-4); margin-top: var(--space-4);">
          <% @stack.each do |tech| %>
            <% tag_class = case tech.downcase
              when "rails" then "tag--rails"
              when "postgresql" then "tag--postgres"
              when "hotwire" then "tag--hotwire"
              when "solid queue" then "tag--sidekiq"
              when "docker" then "tag--sidekiq"
              when "grafana" then "tag--postgres"
              when "stripe" then "tag--stripe"
              when "fly.io" then "tag--accent"
              when "claude code" then "tag--hotwire"
              else "tag--neutral"
              end %>
            <span class="tag <%= tag_class %>" style="padding: 8px 16px; font-size: var(--text-base); font-weight: var(--weight-semibold);"><%= tech %></span>
          <% end %>
        </div>
      </div>

      <!-- Row 2: Also Card (col-span-1, custom green) - Rotating -->
      <a
        href="<%= @also_roles.first[:url] %>"
        target="_blank"
        rel="noopener noreferrer"
        class="col-span-1"
        style="text-decoration: none; display: block; position: relative;"
        data-controller="rotating-card"
        data-rotating-card-projects-value="<%= @also_roles.to_json %>"
        data-rotating-card-interval-value="5000"
        data-action="mouseenter->rotating-card#pause mouseleave->rotating-card#resume"
      >
        <!-- Timer indicator -->
        <div style="position: absolute; top: var(--space-4); right: var(--space-4); z-index: 10;">
          <svg width="20" height="20" viewBox="0 0 20 20" style="transform: rotate(-90deg);">
            <circle
              cx="10"
              cy="10"
              r="8"
              fill="none"
              stroke="rgba(52, 217, 138, 0.2)"
              stroke-width="2"
            />
            <circle
              cx="10"
              cy="10"
              r="8"
              fill="none"
              stroke="rgba(52, 217, 138, 0.8)"
              stroke-width="2"
              stroke-linecap="round"
              data-rotating-card-target="progress"
              style="transition: stroke-dashoffset 0.1s linear;"
            />
          </svg>
        </div>

        <div class="card" data-rotating-card-target="card" style="background: linear-gradient(135deg, #1a4d2e 0%, #0d2818 100%); border-color: rgba(52, 217, 138, 0.2); transition: opacity 0.3s ease, transform 0.3s ease; height: 100%;">
          <p class="card__label" style="color: rgba(52, 217, 138, 0.7);">Also</p>
          <h2 class="card__title" style="color: white; font-size: var(--text-2xl); margin-bottom: var(--space-2);" data-card-title><%= @also_roles.first[:name] %></h2>
          <p style="color: rgba(255,255,255,0.8); font-size: var(--text-base);" data-card-description><%= @also_roles.first[:description] %></p>
        </div>
      </a>

      <!-- Row 2: Open Source Card (col-span-1) - Rotating -->
      <a
        href="<%= @open_source_projects.first[:url] %>"
        target="_blank"
        rel="noopener noreferrer"
        class="col-span-1"
        style="text-decoration: none; display: block; position: relative;"
        data-controller="rotating-card"
        data-rotating-card-projects-value="<%= @open_source_projects.to_json %>"
        data-rotating-card-interval-value="7000"
        data-action="mouseenter->rotating-card#pause mouseleave->rotating-card#resume"
      >
        <!-- Timer indicator -->
        <div style="position: absolute; top: var(--space-4); right: var(--space-4); z-index: 10;">
          <svg width="20" height="20" viewBox="0 0 20 20" style="transform: rotate(-90deg);">
            <circle
              cx="10"
              cy="10"
              r="8"
              fill="none"
              stroke="var(--border-medium)"
              stroke-width="2"
            />
            <circle
              cx="10"
              cy="10"
              r="8"
              fill="none"
              stroke="var(--accent)"
              stroke-width="2"
              stroke-linecap="round"
              data-rotating-card-target="progress"
              style="transition: stroke-dashoffset 0.1s linear;"
            />
          </svg>
        </div>

        <div class="card" data-rotating-card-target="card" style="transition: opacity 0.3s ease, transform 0.3s ease; height: 100%;">
          <p class="card__label">Open Source</p>
          <h2 class="card__title" style="font-size: var(--text-2xl); margin-bottom: var(--space-2);" data-card-title><%= @open_source_projects.first[:name] %></h2>
          <p class="text-body" data-card-description><%= @open_source_projects.first[:description] %></p>
        </div>
      </a>
    </div>

    <!-- Chat CTA Section -->
    <div style="margin-top: var(--space-16); text-align: center;">
      <div style="display: flex; justify-content: center; gap: var(--space-4); flex-wrap: wrap;">
        <%= link_to new_chat_path,
            data: { turbo_frame: 'overlay' },
            class: "btn btn--primary btn--lg",
            style: "gap: var(--space-3); display: inline-flex; align-items: center;" do %>
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
          </svg>
          Ask AI About Nathan
        <% end %>
        <%= link_to new_fit_check_path,
            data: { turbo_frame: 'overlay' },
            class: "btn btn--lg",
            style: "gap: var(--space-3); display: inline-flex; align-items: center; border: 1px solid var(--border-medium); color: var(--text-primary); background: var(--bg-card-subtle);" do %>
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
          </svg>
          Fit Check
        <% end %>
        <%= mail_to "natejones@hey.com",
            class: "btn btn--lg",
            style: "gap: var(--space-3); display: inline-flex; align-items: center; border: 1px solid var(--border-medium); color: var(--text-primary); background: var(--bg-card-subtle);" do %>
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          Say Hello
        <% end %>
      </div>
      <p class="text-caption" style="margin-top: var(--space-4);">
        Chat with an AI that knows Nathan's career story
      </p>
    </div>

    <!-- Strengths / Moderate / Gaps Section -->
    <div class="skills-grid" style="margin-top: var(--space-16);">
      <!-- Strong -->
      <div class="card card--strong">
        <p class="card__label">Strong</p>
        <ul class="skills-list">
          <% @self_assessment[:strong].each do |skill| %>
            <li><span class="skills-icon">&#10003;</span> <%= skill %></li>
          <% end %>
        </ul>
      </div>

      <!-- Moderate -->
      <div class="card">
        <p class="card__label">Moderate</p>
        <ul class="skills-list">
          <% @self_assessment[:moderate].each do |skill| %>
            <li><span class="skills-icon" style="color: var(--text-tertiary);">&#9675;</span> <%= skill %></li>
          <% end %>
        </ul>
      </div>

      <!-- Gaps -->
      <div class="card card--gaps">
        <p class="card__label">Gaps (I'll Tell You)</p>
        <ul class="skills-list">
          <% @self_assessment[:gaps].each do |skill| %>
            <li><span class="skills-icon">&#10005;</span> <%= skill %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
