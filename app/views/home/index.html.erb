<div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white">
  <!-- Hero Section -->
  <div class="container mx-auto px-4 py-16 md:py-24">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl font-bold mb-4">
        <%= @profile["name"] %>
      </h1>
      <p class="text-2xl md:text-3xl text-gray-300 mb-2">
        <%= @profile["title"] %>
      </p>
      <p class="text-lg md:text-xl text-gray-400 mb-8">
        <%= @profile["tagline"] %>
      </p>

      <!-- Ask AI Button -->
      <button
        data-controller="chat-overlay"
        data-action="click->chat-overlay#open"
        class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-lg transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
        </svg>
        Ask AI About Nathan
      </button>

      <p class="mt-4 text-sm text-gray-500">
        Chat with an AI that knows Nathan's career story
      </p>
    </div>
  </div>

  <!-- Suggested Questions -->
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-6 text-center">Common Questions</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <% [
          "What kind of leadership experience do they have?",
          "Tell me about their biggest failure.",
          "How did they reduce costs by $1.2M? Was it technical or political?",
          "Would this person be good for a Series B startup with messy data infrastructure?"
        ].each do |question| %>
          <button
            data-controller="chat-overlay"
            data-action="click->chat-overlay#openWithQuestion"
            data-chat-overlay-question-value="<%= question %>"
            class="text-left p-4 bg-gray-800 hover:bg-gray-700 rounded-lg transition-colors border border-gray-700 hover:border-gray-600"
          >
            <p class="text-gray-300"><%= question %></p>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Experience Timeline -->
  <div class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-12 text-center">Experience</h2>

      <div class="space-y-8">
        <% @experiences.each_with_index do |experience, index| %>
          <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-2xl font-bold"><%= experience["company"] %></h3>
                <p class="text-lg text-gray-300"><%= experience["role"] %></p>
              </div>
              <p class="text-gray-400"><%= experience["period"] %></p>
            </div>

            <ul class="list-disc list-inside space-y-2 mb-4">
              <% experience["highlights"].each do |highlight| %>
                <li class="text-gray-300"><%= highlight %></li>
              <% end %>
            </ul>

            <details class="mt-4">
              <summary class="cursor-pointer text-blue-400 hover:text-blue-300 font-medium">
                View AI Context &rarr;
              </summary>
              <div class="mt-4 p-4 bg-gray-900 rounded border border-gray-700">
                <p class="text-gray-300 whitespace-pre-line"><%= experience["ai_context"] %></p>
              </div>
            </details>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Values -->
  <div class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-8 text-center">Core Values</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <% @values.each do |value| %>
          <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
            <p class="text-gray-300"><%= value %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Projects -->
  <div class="container mx-auto px-4 py-16 pb-24">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-8 text-center">Notable Projects</h2>
      <div class="space-y-4">
        <% @projects.each do |project| %>
          <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-xl font-bold"><%= project["name"] %></h3>
              <p class="text-gray-400 text-sm"><%= project["date"] %></p>
            </div>
            <p class="text-gray-300 mb-2"><%= project["description"] %></p>
            <p class="text-gray-400 text-sm"><%= project["details"] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
