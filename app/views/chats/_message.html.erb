<% if defined?(message) && message.is_a?(Message) %>
  <% role = message.role %>
  <% content = message.content %>
<% end %>

<% if role != 'system' %>
  <div style="display: flex; <%= role == 'user' ? 'justify-content: flex-end;' : 'justify-content: flex-start;' %>; margin-bottom: var(--space-6);">
    <div
      class="<%= role == 'user' ? 'card--accent' : 'card--subtle' %>"
      style="
        padding: var(--space-4);
        border-radius: var(--radius-md);
        max-width: 80%;
        <%= role == 'user' ? 'color: white;' : '' %>
      "
    >
      <p class="text-caption" style="margin-bottom: var(--space-2); <%= role == 'user' ? 'color: rgba(255,255,255,0.7);' : '' %>; text-transform: uppercase; font-weight: var(--weight-semibold); letter-spacing: 0.05em;">
        <%= role == 'user' ? 'You' : 'AI' %>
      </p>
      <div class="text-body" style="<%= role == 'user' ? 'color: white;' : '' %>">
        <%= simple_format(content) %>
      </div>
    </div>
  </div>
<% end %>
