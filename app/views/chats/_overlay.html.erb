<!-- Chat Overlay -->
<div
  data-controller="chat-overlay"
  data-chat-overlay-target="overlay"
  data-action="click->chat-overlay#closeOnBackdrop keydown@window->chat-overlay#closeOnEscape"
  class="hidden fixed inset-0 bg-black bg-opacity-75 z-50 flex items-center justify-center p-4"
>
  <div class="bg-gray-900 rounded-lg shadow-2xl w-full max-w-2xl max-h-[90vh] flex flex-col border border-gray-700">
    <!-- Header -->
    <div class="flex items-center justify-between p-4 border-b border-gray-700">
      <h2 class="text-xl font-bold text-white">Chat with AI About Nathan</h2>
      <button
        data-action="click->chat-overlay#close"
        class="text-gray-400 hover:text-white transition-colors"
        aria-label="Close chat"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Messages Area -->
    <% chat_id = session[:chat_id] || "new" %>
    <%= turbo_stream_from "chat_#{chat_id}" %>

    <div
      data-controller="chat-form"
      data-chat-form-target="messages"
      id="chat_messages"
      class="flex-1 overflow-y-auto p-4 space-y-4"
    >
      <div id="messages">
        <div class="text-center text-gray-400 py-8">
          <p class="mb-2">👋 Hi! I'm an AI that knows Nathan's career story.</p>
          <p class="text-sm">Ask me anything about his experience, achievements, or working style.</p>
        </div>
      </div>
    </div>

    <!-- Input Form -->
    <div class="p-4 border-t border-gray-700">
      <%= form_with(
        url: ask_chat_path(id: "new"),
        method: :post,
        data: {
          controller: "chat-form",
          action: "submit->chat-form#submit",
          turbo_frame: "messages"
        },
        class: "flex gap-2"
      ) do |f| %>
        <%= f.text_field :message,
          placeholder: "Ask about Nathan's experience...",
          class: "flex-1 bg-gray-800 text-white rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-700",
          autocomplete: "off",
          data: {
            chat_overlay_target: "input",
            chat_form_target: "input"
          }
        %>
        <%= f.submit "Send",
          class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        %>
      <% end %>
    </div>
  </div>
</div>
