<!-- Chat Overlay -->
<div
  data-controller="chat-overlay"
  data-chat-overlay-target="overlay"
  data-action="click->chat-overlay#closeOnBackdrop keydown@window->chat-overlay#closeOnEscape"
  style="
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    z-index: 50;
    padding: var(--space-4);
  "
  class="flex items-center justify-center"
>
  <div
    class="card"
    style="
      width: 100%;
      max-width: 800px;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      box-shadow: var(--shadow-popover);
    "
  >
    <!-- Header -->
    <div
      style="
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-5);
        border-bottom: 1px solid var(--border-medium);
      "
    >
      <h2 class="text-heading">Chat with AI About Nathan</h2>
      <button
        data-action="click->chat-overlay#close"
        class="btn btn--ghost"
        style="width: 40px; height: 40px; padding: 0; border-radius: var(--radius-md);"
        aria-label="Close chat"
      >
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Messages Area -->
    <% chat_id = session[:chat_id] || "new" %>
    <%= turbo_stream_from "chat_#{chat_id}" %>

    <div
      data-controller="chat-form"
      data-chat-form-target="messages"
      id="chat_messages"
      style="
        flex: 1;
        overflow-y: auto;
        padding: var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      "
    >
      <div id="messages">
        <div style="text-align: center; padding: var(--space-8) 0; color: var(--text-tertiary);">
          <p class="text-body" style="margin-bottom: var(--space-2);">👋 Hi! I'm an AI that knows Nathan's career story.</p>
          <p class="text-body">Ask me anything about his experience, achievements, or working style.</p>
        </div>
      </div>
    </div>

    <!-- Input Form -->
    <div style="padding: var(--space-5); border-top: 1px solid var(--border-medium);">
      <%= form_with(
        url: ask_chat_path(id: "new"),
        method: :post,
        data: {
          controller: "chat-form",
          action: "submit->chat-form#submit",
          turbo_frame: "messages"
        },
        style: "display: flex; gap: var(--space-3);"
      ) do |f| %>
        <%= f.text_field :message,
          placeholder: "Ask about Nathan's experience...",
          style: "
            flex: 1;
            background: var(--bg-card-subtle);
            color: var(--text-primary);
            border-radius: var(--radius-md);
            padding: var(--space-4);
            border: 1px solid var(--border-medium);
            font-family: var(--font-sans);
            font-size: var(--text-base);
            outline: none;
            transition: border-color var(--duration-fast) var(--ease-out);
          ",
          autocomplete: "off",
          data: {
            chat_overlay_target: "input",
            chat_form_target: "input"
          },
          onfocus: "this.style.borderColor='var(--accent-border)'",
          onblur: "this.style.borderColor='var(--border-medium)'"
        %>
        <%= f.submit "Send",
          class: "btn btn--primary"
        %>
      <% end %>
    </div>
  </div>
</div>
