<%= turbo_frame_tag 'overlay' do %>
  <% chat_id = session[:chat_id] || "new" %>
  <%= render layout: 'layouts/overlay', locals: {
    title: "Chat with AI About Nathan",
    size: 'max-w-4xl',
    header_actions: (chat_id != "new" ? link_to(export_chat_path(chat_id, format: :txt),
      class: "btn btn--ghost",
      style: "display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-4); font-size: var(--text-sm);",
      target: "_blank") {
        raw('<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg> Export')
      } : nil)
  } do %>
    <div data-controller="chat-form" style="display: flex; flex-direction: column; height: 100%;">
      <!-- Messages Area -->
      <% chat_id = session[:chat_id] || "new" %>
      <%= turbo_stream_from "chat_#{chat_id}" %>

      <div data-chat-form-target="messages"
           id="chat_messages"
           style="flex: 1; overflow-y: auto; margin-bottom: var(--space-6);">
        <div id="messages">
          <div id="chat_empty_state" style="text-align: center; padding: var(--space-2) 0; color: var(--text-tertiary);">
            <p class="text-body" style="margin-bottom: var(--space-2);">👋 Hi! I'm an AI that knows Nathan's career story.</p>
            <p class="text-body">Ask me anything about his experience, achievements, or working style.</p>
          </div>

          <!-- Suggested Questions -->
          <div id="suggested_questions" style="display: flex; flex-direction: column; gap: var(--space-3); margin-top: var(--space-6);">
            <% [
              "What's Nathan's experience with Rails and Hotwire?",
              "Tell me about Nathan's approach to building SaaS products",
              "What open source projects has Nathan built?",
              "How does Nathan approach technical leadership?"
            ].each do |question| %>
              <%= button_to ask_chat_path(id: "new", message: question),
                  method: :post,
                  data: { turbo_frame: "messages" },
                  class: "btn btn--ghost",
                  style: "
                    text-align: left;
                    justify-content: flex-start;
                    white-space: normal;
                    word-break: break-word;
                    box-sizing: border-box;
                    padding: var(--space-4);
                    border: 1px solid var(--border-medium);
                    border-radius: var(--radius-md);
                    background: var(--bg-card-subtle);
                    color: var(--text-secondary);
                    font-size: var(--text-base);
                    transition: all var(--duration-fast) var(--ease-out);
                    width: 100%;
                    cursor: pointer;
                  ",
                  onmouseover: "this.style.borderColor='var(--accent-border)'; this.style.background='var(--bg-card)'",
                  onmouseout: "this.style.borderColor='var(--border-medium)'; this.style.background='var(--bg-card-subtle)'" do %>
                "<%= question %>"
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Input Form -->
      <%= form_with(
        url: ask_chat_path(id: "new"),
        method: :post,
        data: {
          action: "submit->chat-form#submit",
          turbo_frame: "messages"
        },
        class: 'flex items-center gap-3'
      ) do |f| %>
        <%= f.text_field :message,
          placeholder: "Ask about Nathan's experience...",
          style: "
            flex: 1;
            height: 48px;
            background: var(--bg-card-subtle);
            color: var(--text-primary);
            border-radius: var(--radius-md);
            padding: var(--space-4);
            border: 1px solid var(--border-medium);
            font-family: var(--font-sans);
            font-size: var(--text-base);
            outline: none;
            transition: border-color var(--duration-fast) var(--ease-out);
            min-width: 0;
            box-sizing: border-box;
          ",
          autocomplete: "off",
          data: { chat_form_target: "input" },
          onfocus: "this.style.borderColor='var(--accent-border)'",
          onblur: "this.style.borderColor='var(--border-medium)'"
        %>
        <button
          type="submit"
          class="btn btn--primary"
          style="
            width: 48px;
            height: 48px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-md);
            flex-shrink: 0;
          "
          aria-label="Send message"
        >
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="transform: rotate(45deg);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
          </svg>
        </button>
      <% end %>
    </div>
  <% end %>
<% end %>
