<%= turbo_frame_tag 'overlay' do %>
  <%= render layout: 'layouts/overlay', locals: {
    title: "Fit Check",
    size: 'max-w-2xl'
  } do %>
    <div data-controller="fit-check" style="display: flex; flex-direction: column; height: 100%;">
      <p class="text-body" style="margin-bottom: var(--space-6); color: var(--text-secondary);">
        Paste a job description and get an honest AI assessment of Nathan's fit for the role.
      </p>

      <%= form_with(
        url: fit_check_path,
        method: :post,
        data: {
          action: "submit->fit-check#submit"
        }
      ) do |f| %>
        <%= f.text_area :job_description,
          placeholder: "Paste the full job description here...",
          rows: 8,
          data: { fit_check_target: "textarea" },
          style: "
            width: 100%;
            background: var(--bg-card-subtle);
            color: var(--text-primary);
            border-radius: var(--radius-md);
            padding: var(--space-4);
            border: 1px solid var(--border-medium);
            font-family: var(--font-sans);
            font-size: var(--text-base);
            outline: none;
            resize: vertical;
            transition: border-color var(--duration-fast) var(--ease-out);
            box-sizing: border-box;
          ",
          onfocus: "this.style.borderColor='var(--accent-border)'",
          onblur: "this.style.borderColor='var(--border-medium)'"
        %>

        <button
          type="submit"
          class="btn btn--primary"
          data-fit-check-target="submit"
          style="
            margin-top: var(--space-4);
            width: 100%;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--space-3);
            border-radius: var(--radius-md);
          "
        >
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
          </svg>
          <span data-fit-check-target="submitText">Check Fit</span>
        </button>
      <% end %>

      <!-- Result area -->
      <div id="fit_check_result" style="margin-top: var(--space-6);"></div>
    </div>
  <% end %>
<% end %>
